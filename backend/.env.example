# MPS POS — backend environment template.
# Copy to `.env` and fill in real values. NEVER commit the real .env.

# ── Database ──
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public"

# ── Auth / JWT ──
JWT_SECRET="change-me"
JWT_REFRESH_SECRET="change-me"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ── Redis (optional — app falls back to in-memory if unavailable) ──
REDIS_HOST="localhost"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ── App ──
NODE_ENV="development"
PORT="3000"
APP_URL="http://localhost:3000"
POS_API_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"
RATE_LIMIT_TTL="60000"
RATE_LIMIT_LIMIT="100"

# ── Google Drive (file storage) ──
GOOGLE_DRIVE_CLIENT_EMAIL=""
GOOGLE_DRIVE_PRIVATE_KEY=""
GOOGLE_DRIVE_PROJECT_ID=""
GOOGLE_SHARED_DRIVE_REPAIRS_FOLDER_ID=""
GOOGLE_SHARED_DRIVE_CUSTOMERS_FOLDER_ID=""
GOOGLE_SHARED_DRIVE_PRODUCTS_FOLDER_ID=""
GOOGLE_SHARED_DRIVE_RECEIPTS_FOLDER_ID=""
GOOGLE_DRIVE_PARENT_FOLDER_ID=""
GOOGLE_DRIVE_TENANT_IDS=""

# ── Security ──
ENCRYPTION_KEY="change-me"
HASH_SALT_ROUNDS="10"
INTERNAL_API_KEY="change-me"

# ── Multi-tenant ──
MAINFRAME_BACKEND_URL="http://localhost:3001/api/v1"
DEFAULT_TENANT_ID=""
TENANT_DOMAIN_MAPPING='{"localhost":"your-tenant"}'

# ── Email (SMTP) ──
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASSWORD=""

# ── SMS (VoodooSMS) ──
VOODOOSMS_API_KEY=""
VOODOOSMS_SENDER_ID=""

# ── Stripe ──
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# ── OpenAI ──
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_MAX_TOKENS="1000"

# ── LemonSqueezy (subscriptions) ──
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_WEBHOOK_SECRET=""
LS_STORE_ID=""
LS_VARIANT_ID=""

# ── Gold price feed ──
GOLD_API_KEY=""

# ── Observability / Sentry (optional) ──
# Leave SENTRY_DSN empty to disable error tracking entirely (no-op).
# Set it to your Sentry project DSN to start capturing 5xx errors.
SENTRY_DSN=""
SENTRY_TRACES_SAMPLE_RATE="0.1"
SENTRY_RELEASE=""
