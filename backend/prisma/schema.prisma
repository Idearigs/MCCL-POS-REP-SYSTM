// ─── HRMS Models ──────────────────────────────────────────────────────────────

model hrms_departments {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  code        String?
  description String?
  managerId   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees hrms_employees[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

model hrms_positions {
  id          String  @id @default(uuid())
  tenantId    String
  title       String
  code        String?
  description String?
  department  String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees hrms_employees[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model hrms_employees {
  id             String             @id @default(uuid())
  tenantId       String
  employeeNumber String

  // Personal info
  title          HrmsTitleType?
  firstName      String
  middleName     String?
  lastName       String
  preferredName  String?
  gender         HrmsGender?
  dateOfBirth    DateTime?
  maritalStatus  HrmsMaritalStatus?
  nationality    String?
  ethnicity      String?

  // Contact
  personalEmail  String?
  workEmail      String?
  personalPhone  String?
  workPhone      String?

  // Address
  addressLine1   String?
  addressLine2   String?
  city           String?
  county         String?
  postcode       String?
  country        String             @default("GB")

  // Employment
  departmentId   String?
  positionId     String?
  managerId      String?
  jobTitle       String?
  status         HrmsEmployeeStatus @default(PROBATION)
  employmentType HrmsEmploymentType @default(FULL_TIME)
  contractType   HrmsContractType   @default(PERMANENT)
  startDate      DateTime
  endDate        DateTime?
  probationEndDate DateTime?
  noticePeriodDays Int?

  // Payroll
  niNumber       String?            // AES-256 encrypted
  taxCode        String?            @default("1257L")
  niCategory     HrmsNiCategory     @default(A)
  payFrequency   HrmsPayFrequency   @default(MONTHLY)
  salary         Decimal?           @db.Decimal(10, 2)
  hourlyRate     Decimal?           @db.Decimal(10, 4)
  contractedHours Decimal?          @db.Decimal(5, 2)

  // Banking (encrypted)
  bankAccountName String?           // AES-256 encrypted
  bankSortCode   String?            // AES-256 encrypted
  bankAccountNo  String?            // AES-256 encrypted
  bankName       String?

  // HMRC starter
  starterDeclaration HrmsStarterDeclaration?
  p45Received    Boolean            @default(false)

  // Pension auto-enrolment
  pensionEligible Boolean           @default(false)
  pensionEnrolled Boolean           @default(false)
  pensionOptOut  Boolean            @default(false)
  pensionOptOutDate DateTime?
  employerPensionPct Decimal?       @db.Decimal(5, 2) @default(3.00)
  employeePensionPct Decimal?       @db.Decimal(5, 2) @default(5.00)

  // Holiday
  annualLeaveEntitlement Decimal    @db.Decimal(5, 2) @default(28.00)
  holidayYearStart DateTime?

  // Student loan
  studentLoanPlan String?

  // Right to work
  rightToWorkChecked Boolean        @default(false)
  rightToWorkExpiry  DateTime?

  // Emergency contact
  emergencyName  String?
  emergencyPhone String?
  emergencyRelation String?

  notes          String?
  isActive       Boolean            @default(true)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  department     hrms_departments?  @relation(fields: [departmentId], references: [id])
  position       hrms_positions?    @relation(fields: [positionId], references: [id])
  leaveRequests  hrms_leave_requests[]
  documents      hrms_employee_documents[]
  payslips       hrms_payslips[]
  timesheets        hrms_timesheets[]
  timesheetEntries  hrms_timesheet_entries[]
  timesheetTokens   hrms_timesheet_tokens[]
  p11dBenefits      hrms_p11d_benefits[]

  @@unique([tenantId, employeeNumber])
  @@index([tenantId, status])
  @@index([tenantId, departmentId])
  @@index([tenantId, isActive])
}

model hrms_leave_requests {
  id             String          @id @default(uuid())
  tenantId       String
  employeeId     String
  leaveType      HrmsLeaveType
  status         HrmsLeaveStatus @default(PENDING)
  startDate      DateTime
  endDate        DateTime
  days           Decimal         @db.Decimal(5, 2)
  notes          String?
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  employee hrms_employees @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
  @@index([tenantId, status])
  @@index([tenantId, startDate])
}

model hrms_employee_documents {
  id          String           @id @default(uuid())
  tenantId    String
  employeeId  String
  type        HrmsDocumentType @default(OTHER)
  fileName    String
  filePath    String?
  driveFileId String?
  uploadedBy  String
  notes       String?
  expiryDate  DateTime?
  createdAt   DateTime         @default(now())

  employee hrms_employees @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
  @@index([tenantId, type])
}

// ─── HRMS Payroll Models ───────────────────────────────────────────────────────

enum HrmsPayrollStatus {
  DRAFT
  PROCESSING
  COMPLETED
  LOCKED
}

enum HrmsPayslipStatus {
  DRAFT
  FINAL
}

model hrms_payroll_runs {
  id           String            @id @default(uuid())
  tenantId     String
  periodStart  DateTime
  periodEnd    DateTime
  payDate      DateTime
  payFrequency HrmsPayFrequency  @default(MONTHLY)
  status       HrmsPayrollStatus @default(DRAFT)

  employeeCount        Int     @default(0)
  totalGross           Decimal @db.Decimal(12, 2) @default(0)
  totalTax             Decimal @db.Decimal(12, 2) @default(0)
  totalEmployeeNI      Decimal @db.Decimal(12, 2) @default(0)
  totalEmployerNI      Decimal @db.Decimal(12, 2) @default(0)
  totalEmployeePension Decimal @db.Decimal(12, 2) @default(0)
  totalEmployerPension Decimal @db.Decimal(12, 2) @default(0)
  totalNetPay          Decimal @db.Decimal(12, 2) @default(0)

  createdBy   String
  processedAt DateTime?
  lockedAt    DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  payslips hrms_payslips[]

  @@index([tenantId, status])
  @@index([tenantId, payDate])
}

model hrms_payslips {
  id             String           @id @default(uuid())
  tenantId       String
  payrollRunId   String
  employeeId     String
  employeeNumber String
  employeeName   String
  payPeriodStart DateTime
  payPeriodEnd   DateTime
  payDate        DateTime
  payFrequency   HrmsPayFrequency @default(MONTHLY)
  taxCode        String           @default("1257L")
  niCategory     HrmsNiCategory   @default(A)

  basicPay       Decimal @db.Decimal(10, 2) @default(0)
  overtimePay    Decimal @db.Decimal(10, 2) @default(0)
  bonusPay       Decimal @db.Decimal(10, 2) @default(0)
  commissionPay  Decimal @db.Decimal(10, 2) @default(0)
  sickPay        Decimal @db.Decimal(10, 2) @default(0)
  holidayPay     Decimal @db.Decimal(10, 2) @default(0)
  otherAdditions Decimal @db.Decimal(10, 2) @default(0)
  grossPay       Decimal @db.Decimal(10, 2) @default(0)

  paye                 Decimal @db.Decimal(10, 2) @default(0)
  employeeNI           Decimal @db.Decimal(10, 2) @default(0)
  employerNI           Decimal @db.Decimal(10, 2) @default(0)
  employeePension      Decimal @db.Decimal(10, 2) @default(0)
  employerPension      Decimal @db.Decimal(10, 2) @default(0)
  studentLoanRepayment Decimal @db.Decimal(10, 2) @default(0)
  otherDeductions      Decimal @db.Decimal(10, 2) @default(0)
  totalDeductions      Decimal @db.Decimal(10, 2) @default(0)
  netPay               Decimal @db.Decimal(10, 2) @default(0)

  pensionEligible Boolean @default(false)
  pensionEnrolled Boolean @default(false)

  ytdGross      Decimal @db.Decimal(10, 2) @default(0)
  ytdTax        Decimal @db.Decimal(10, 2) @default(0)
  ytdEmployeeNI Decimal @db.Decimal(10, 2) @default(0)

  status    HrmsPayslipStatus @default(DRAFT)
  notes     String?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  payrollRun hrms_payroll_runs @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employee   hrms_employees    @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@unique([payrollRunId, employeeId])
  @@index([tenantId, employeeId])
  @@index([tenantId, payrollRunId])
  @@index([tenantId, payDate])
}

// ─── HRMS Time & Attendance Models ────────────────────────────────────────────

enum HrmsTimesheetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum HrmsEntryType {
  REGULAR
  OVERTIME
  SICK
  ANNUAL_LEAVE
  BANK_HOLIDAY
  TRAINING
  UNPAID
  OTHER
}

model hrms_timesheets {
  id            String              @id @default(uuid())
  tenantId      String
  employeeId    String
  weekStartDate DateTime            @db.Date
  status        HrmsTimesheetStatus @default(DRAFT)
  totalHours    Decimal             @db.Decimal(6, 2) @default(0)
  regularHours  Decimal             @db.Decimal(6, 2) @default(0)
  overtimeHours Decimal             @db.Decimal(6, 2) @default(0)
  submittedAt   DateTime?
  approvedById  String?
  approvedAt    DateTime?
  rejectedReason String?
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  employee hrms_employees          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  entries  hrms_timesheet_entries[]

  @@unique([tenantId, employeeId, weekStartDate])
  @@index([tenantId, weekStartDate])
  @@index([tenantId, employeeId])
  @@index([tenantId, status])
}

model hrms_timesheet_entries {
  id           String        @id @default(uuid())
  tenantId     String
  timesheetId  String
  employeeId   String
  entryDate    DateTime      @db.Date
  startTime    String?
  endTime      String?
  breakMinutes Int           @default(0)
  hoursWorked  Decimal       @db.Decimal(5, 2) @default(0)
  entryType    HrmsEntryType @default(REGULAR)
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  timesheet hrms_timesheets @relation(fields: [timesheetId], references: [id], onDelete: Cascade)
  employee  hrms_employees  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([timesheetId, entryDate])
  @@index([tenantId, employeeId, entryDate])
}

model hrms_timesheet_tokens {
  id          String   @id @default(uuid())
  tenantId    String
  employeeId  String
  token       String   @unique
  weekStart   DateTime @db.Date
  weekEnd     DateTime @db.Date
  pinHash     String?
  status      String   @default("PENDING")
  submittedAt DateTime?
  createdAt   DateTime @default(now())
  expiresAt   DateTime

  employee hrms_employees @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, employeeId])
  @@index([token])
}

model hrms_bank_holidays {
  id        String   @id @default(uuid())
  tenantId  String?
  name      String
  date      DateTime @db.Date
  region    String   @default("ENGLAND_WALES")
  createdAt DateTime @default(now())

  @@index([date])
  @@index([tenantId, date])
}

enum HrmsP11dBenefitType {
  COMPANY_CAR
  MEDICAL_INSURANCE
  LIFE_INSURANCE
  GYM_MEMBERSHIP
  INTEREST_FREE_LOAN
  VOUCHERS
  ACCOMMODATION
  TRAVEL_SUBSISTENCE
  ENTERTAINMENT
  OTHER
}

model hrms_p11d_benefits {
  id              String              @id @default(uuid())
  tenantId        String
  employeeId      String
  taxYear         String
  benefitType     HrmsP11dBenefitType @default(OTHER)
  description     String
  cashEquivalent  Decimal             @db.Decimal(10, 2)
  notes           String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  employee hrms_employees @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([tenantId, taxYear])
  @@index([tenantId, employeeId, taxYear])
}

model gift_cards {
  id             String        @id
  tenantId       String
  code           String        @unique
  initialBalance Decimal       @db.Decimal(10, 2)
  balance        Decimal       @db.Decimal(10, 2)
  status         GiftCardStatus @default(ACTIVE)
  recipientName  String?
  recipientEmail String?
  purchasedBy    String?
  expiresAt      DateTime?
  notes          String?
  createdBy      String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenants        tenants       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users          users         @relation("GiftCardCreatedBy", fields: [createdBy], references: [id])
  transactions   gift_card_transactions[]

  @@index([tenantId, status])
  @@index([tenantId, code])
}

model gift_card_transactions {
  id          String   @id
  giftCardId  String
  amount      Decimal  @db.Decimal(10, 2)
  type        String
  reference   String?
  performedBy String
  createdAt   DateTime @default(now())

  giftCard    gift_cards @relation(fields: [giftCardId], references: [id], onDelete: Cascade)

  @@index([giftCardId])
}
