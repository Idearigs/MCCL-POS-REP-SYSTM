generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model audit_logs {
  id        String   @id
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  oldData   Json?
  newData   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  users     users?   @relation(fields: [userId], references: [id])
}

model calendar_events {
  id          String    @id
  tenantId    String
  createdBy   String
  title       String
  description String?
  eventDate   DateTime
  eventType   EventType @default(APPOINTMENT)
  isAllDay    Boolean   @default(false)
  startTime   String?
  endTime     String?
  location    String?
  customerId  String?
  repairId    String?
  reminderId  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime
  tenants     tenants   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       users     @relation(fields: [createdBy], references: [id])
}

model categories {
  id               String       @id
  tenantId         String
  name             String
  description      String?
  parentId         String?
  isActive         Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime
  categories       categories?  @relation("categoriesTocategories", fields: [parentId], references: [id])
  other_categories categories[] @relation("categoriesTocategories")
  tenants          tenants      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products         products[]
}

model customers {
  id                    String      @id
  tenantId              String
  firstName             String
  lastName              String
  email                 String?
  phone                 String
  address               String?
  city                  String?
  postalCode            String?
  country               String?
  birthDate             DateTime?
  anniversaryDate       DateTime?
  notes                 String?
  totalSpent            Decimal     @default(0)
  visitCount            Int         @default(0)
  loyaltyPoints         Int         @default(0)
  preferredContact      ContactType @default(EMAIL)
  marketingEmail        Boolean     @default(false)
  marketingSms          Boolean     @default(false)
  marketingPhone        Boolean     @default(false)
  dataProcessingConsent Boolean     @default(false)
  consentDate           DateTime?
  isActive              Boolean     @default(true)
  redFlag               Boolean     @default(false)
  redFlagReason         String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime
  tenants               tenants     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents             documents[]
  repairs               repairs[]
  sales                 sales[]
}

model documents {
  id            String       @id
  tenantId      String
  customerId    String?
  uploadedBy    String
  fileName      String
  originalName  String
  filePath      String
  fileSize      Int
  mimeType      String
  documentType  DocumentType
  driveFileId   String?
  driveViewLink String?
  notes         String?
  isPublic      Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime
  customers     customers?   @relation(fields: [customerId], references: [id])
  tenants       tenants      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users         users        @relation(fields: [uploadedBy], references: [id])
}

model inventory_logs {
  id          String           @id
  tenantId    String
  productId   String
  type        InventoryLogType
  quantity    Int
  previousQty Int
  newQty      Int
  reason      String?
  reference   String?
  createdAt   DateTime         @default(now())
  products    products         @relation(fields: [productId], references: [id], onDelete: Cascade)
  tenants     tenants          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model payments {
  id            String        @id
  saleId        String
  amount        Decimal
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?
  processorData Json?
  createdAt     DateTime      @default(now())
  sales         sales         @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model product_images {
  id            String   @id
  productId     String
  fileName      String
  filePath      String
  driveFileId   String?
  driveViewLink String?
  fileSize      Int
  mimeType      String
  isMain        Boolean  @default(false)
  alt           String?
  createdAt     DateTime @default(now())
  products      products @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model products {
  id             String           @id
  tenantId       String
  name           String
  description    String?
  sku            String
  barcode        String?
  categoryId     String?
  supplierId     String?
  costPrice      Decimal?
  sellingPrice   Decimal
  discountPrice  Decimal?
  stockQuantity  Int              @default(0)
  minStockLevel  Int              @default(1)
  maxStockLevel  Int?
  material       JewelryMaterial?
  weight         Decimal?
  purity         String?
  gemstone       String?
  certification  String?
  color          String?
  size           String?
  location       String?
  isActive       Boolean          @default(true)
  isDamaged      Boolean          @default(false)
  damageNotes    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  supplierName   String?
  inventory_logs inventory_logs[]
  product_images product_images[]
  categories     categories?      @relation(fields: [categoryId], references: [id])
  suppliers      suppliers?       @relation(fields: [supplierId], references: [id])
  tenants        tenants          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale_items     sale_items[]

  // NOTE: SKU and barcode uniqueness is enforced by partial indexes in the database
  // These indexes only apply when isActive = true, allowing SKU/barcode reuse for deleted products
  // See backend/fix-unique-constraints.sql for the actual index definitions
  // Prisma doesn't support partial indexes in schema, so we can't declare them here
}

model repair_photos {
  id            String   @id
  repairId      String
  fileName      String
  filePath      String
  driveFileId   String?
  driveViewLink String?
  fileSize      Int
  mimeType      String
  description   String?
  stage         String?
  createdAt     DateTime @default(now())
  repairs       repairs  @relation(fields: [repairId], references: [id], onDelete: Cascade)
}

model repair_status_history {
  id        String        @id
  repairId  String
  oldStatus RepairStatus?
  newStatus RepairStatus
  notes     String?
  changedBy String
  changedAt DateTime      @default(now())
  repairs   repairs       @relation(fields: [repairId], references: [id], onDelete: Cascade)
}

model repairs {
  id                    String                  @id
  tenantId              String
  customerId            String
  createdBy             String
  repairNumber          String                  @unique
  itemDescription       String
  issueDescription      String
  estimatedCost         Decimal?
  finalCost             Decimal?
  receivedDate          DateTime                @default(now())
  estimatedDueDate      DateTime?
  completedDate         DateTime?
  collectedDate         DateTime?
  status                RepairStatus            @default(RECEIVED)
  priority              RepairPriority          @default(NORMAL)
  customerNotes         String?
  internalNotes         String?
  isInsuranceClaim      Boolean                 @default(false)
  insuranceNumber       String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  repair_photos         repair_photos[]
  repair_status_history repair_status_history[]
  users                 users                   @relation(fields: [createdBy], references: [id])
  customers             customers               @relation(fields: [customerId], references: [id])
  tenants               tenants                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model sale_items {
  id         String   @id
  saleId     String
  productId  String
  quantity   Int
  unitPrice  Decimal
  discount   Decimal  @default(0)
  totalPrice Decimal
  products   products @relation(fields: [productId], references: [id])
  sales      sales    @relation(fields: [saleId], references: [id], onDelete: Cascade)
}

model sales {
  id             String        @id
  tenantId       String
  customerId     String?
  createdBy      String
  saleNumber     String        @unique
  subtotal       Decimal
  taxAmount      Decimal       @default(0)
  discountAmount Decimal       @default(0)
  totalAmount    Decimal
  paymentMethod  PaymentMethod
  paymentStatus  PaymentStatus @default(PENDING)
  paidAmount     Decimal       @default(0)
  changeAmount   Decimal       @default(0)
  notes          String?
  receiptNumber  String?       @unique
  status         SaleStatus    @default(COMPLETED)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime
  balanceDue     Decimal       @default(0)
  refundedAmount Decimal       @default(0)
  payments       payments[]
  sale_items     sale_items[]
  users          users         @relation(fields: [createdBy], references: [id])
  customers      customers?    @relation(fields: [customerId], references: [id])
  tenants        tenants       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model suppliers {
  id            String     @id
  tenantId      String
  name          String
  contactPerson String?
  email         String?
  phone         String?
  address       String?
  website       String?
  notes         String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime
  products      products[]
  tenants       tenants    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model tenants {
  id               String            @id
  name             String
  domain           String            @unique
  subdomain        String            @unique
  settings         Json?
  subscriptionPlan String            @default("basic")
  status           TenantStatus      @default(ACTIVE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime
  calendar_events  calendar_events[]
  categories       categories[]
  customers        customers[]
  documents        documents[]
  inventory_logs   inventory_logs[]
  products         products[]
  repairs          repairs[]
  sales            sales[]
  suppliers        suppliers[]
  users            users[]
}

model users {
  id              String            @id
  tenantId        String
  email           String            @unique
  password        String
  firstName       String
  lastName        String
  role            UserRole          @default(STAFF)
  permissions     Json?
  isActive        Boolean           @default(true)
  lastLogin       DateTime?
  refreshToken    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  audit_logs      audit_logs[]
  calendar_events calendar_events[]
  documents       documents[]
  repairs         repairs[]
  sales           sales[]
  tenants         tenants           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

enum ContactType {
  EMAIL
  PHONE
  SMS
}

enum EventType {
  REPAIR
  DELIVERY
  APPOINTMENT
  OTHER
}

enum DocumentType {
  CONTRACT
  RECEIPT
  INVOICE
  REPAIR_DOCUMENT
  APPRAISAL
  CERTIFICATE
  WARRANTY
  INSURANCE
  OTHER
}

enum InventoryLogType {
  SALE
  PURCHASE
  ADJUSTMENT
  DAMAGE
  RETURN
  TRANSFER
}

enum JewelryMaterial {
  GOLD
  SILVER
  PLATINUM
  DIAMOND
  PEARL
  GEMSTONE
  STAINLESS_STEEL
  OTHER
}

enum PaymentMethod {
  CASH
  CARD
  BANK_TRANSFER
  CHEQUE
  DIGITAL_WALLET
  INSTALLMENT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum RepairPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum RepairStatus {
  RECEIVED
  QUOTED
  APPROVED
  IN_PROGRESS
  COMPLETED
  READY_FOR_COLLECTION
  COLLECTED
  CANCELLED
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
  REFUNDED
}

enum TenantStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
  READONLY
}
