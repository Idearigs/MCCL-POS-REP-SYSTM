DATABASE_URL="postgres://mainframe:password@coolify-container-name:5432/truedesk_mainframe"
JWT_SECRET="mainframe-jwt-secret-change-in-production"
PASSWORD_SALT="truedesk-mainframe-salt"
PORT=3001
CORS_ORIGINS="http://localhost:5174,http://localhost:5173,https://mainframe.truedesk.co.uk"
NODE_ENV=development
MAINFRAME_URL="https://mainframe.truedesk.co.uk"

# POS backend — for provisioning new tenants when a customer profile is created
POS_BACKEND_URL="http://localhost:3002/api/v1"
INTERNAL_API_KEY="change-this-to-a-long-random-secret-shared-with-pos-backend"

# SMTP — Spacemail (mail.spacemail.com)
# Aliases billing@, noreply@, support@ forward to hello@ — use hello@ creds to send.
# The From: header is overridden per email type in each route.
SMTP_HOST="mail.spacemail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="hello@truedesk.co.uk"
SMTP_PASS="your-spacemail-password"
SMTP_FROM="TrueDesk <hello@truedesk.co.uk>"

# LemonSqueezy — webhook signature verification
LEMONSQUEEZY_WEBHOOK_SECRET="your-webhook-signing-secret-from-lemonsqueezy-dashboard"
