DATABASE_URL="postgres://mainframe:password@coolify-container-name:5432/truedesk_mainframe"
JWT_SECRET="mainframe-jwt-secret-change-in-production"
PASSWORD_SALT="truedesk-mainframe-salt"
PORT=3001
CORS_ORIGINS="http://localhost:5174,http://localhost:5173,https://mainframe.truedesk.co.uk"
NODE_ENV=development

# POS backend — for provisioning new tenants when a customer profile is created
POS_BACKEND_URL="http://localhost:3002/api/v1"
INTERNAL_API_KEY="change-this-to-a-long-random-secret-shared-with-pos-backend"

# SMTP — for sending subscription offer emails to tenants
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="TrueDesk <your-email@gmail.com>"
