generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  MANAGER
  STAFF
  READONLY
}

enum CustomerProfileStatus {
  ONBOARDING
  PENDING_SETUP
  ACTIVE
  SUSPENDED
  MAINTENANCE
  DEACTIVATED
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
  CUSTOM
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum FeatureStatus {
  STABLE
  BETA
  ALPHA
  DEPRECATED
  DISABLED
}

enum InternalRole {
  SOFTWARE_DEVELOPER
  RND
  DEVOPS
  SUPPORT
  CYBER_SECURITY
  SYSTEM_ARCHITECT
  SERVER_ADMIN
}

enum RoadmapStatus {
  BACKLOG
  IN_DEV
  ALPHA
  BETA
  SHIPPED
}

enum BugPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum BugStatus {
  OPEN
  IN_PROGRESS
  TESTING
  RESOLVED
  CLOSED
  WONT_FIX
}

enum FeatureRequestStatus {
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  IN_DEVELOPMENT
  TESTING
  RELEASED
  REJECTED
}

model mf_customer_profiles {
  id                       String                 @id @default(uuid())
  businessName             String
  businessEmail            String                 @unique
  businessPhone            String?
  businessAddress          String?
  city                     String?
  country                  String?
  postalCode               String?
  subdomain                String                 @unique
  customDomain             String?
  databaseName             String                 @unique
  databaseHost             String?
  databaseConnectionString String?
  status                   CustomerProfileStatus  @default(PENDING_SETUP)
  setupCompletedAt         DateTime?
  logoUrl                  String?
  primaryColor             String?                @default("#3B82F6")
  secondaryColor           String?                @default("#6366F1")
  contactFirstName         String
  contactLastName          String
  contactEmail             String
  contactPhone             String?
  tradingName              String?
  vatNumber                String?
  onboardingToken          String?                @unique
  onboardingTokenExpiry    DateTime?
  termsAcceptedAt          DateTime?
  internalNotes            String?
  isAlphaTester            Boolean                @default(false)
  isBetaTester             Boolean                @default(false)
  betaExpiresAt            DateTime?
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt
  activityLogs             mf_activity_logs[]
  bugReports               mf_bug_reports[]
  enabledFeatures          mf_customer_features[]
  customerUsers            mf_customer_users[]
  featureRequests          mf_feature_requests[]
  invoices                 mf_invoices[]
  subscription             mf_subscriptions?

  @@index([subdomain])
  @@index([status])
  @@index([businessEmail])
}

model mf_customer_users {
  id                 String               @id @default(uuid())
  customerProfileId  String
  firstName          String
  lastName           String
  email              String
  phone              String?
  passwordHash       String
  passwordSalt       String?
  tempPassword       String?
  mustChangePassword Boolean              @default(true)
  role               UserRole             @default(STAFF)
  permissions        Json?
  isActive           Boolean              @default(true)
  lastLoginAt        DateTime?
  loginAttempts      Int                  @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  customerProfile    mf_customer_profiles @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  passwordHistory    mf_password_history[]

  @@unique([customerProfileId, email])
  @@index([customerProfileId])
  @@index([email])
}

model mf_password_history {
  id       String            @id @default(uuid())
  userId   String
  password String
  setAt    DateTime          @default(now())
  user     mf_customer_users @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([setAt])
}

model mf_features {
  id               String                 @id @default(uuid())
  featureKey       String                 @unique
  featureName      String
  description      String?
  category         String?
  currentVersion   String                 @default("1.0.0")
  betaVersion      String?
  status           FeatureStatus          @default(STABLE)
  isIncludedInBase Boolean                @default(true)
  additionalCost   Decimal?               @default(0)
  dependsOn        String[]               @default([])
  isEnabled        Boolean                @default(true)
  isBeta           Boolean                @default(false)
  requiresSetup    Boolean                @default(false)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  customerFeatures mf_customer_features[]
  versions         mf_feature_versions[]

  @@index([featureKey])
  @@index([status])
}

model mf_feature_versions {
  id                String        @id @default(uuid())
  featureId         String
  version           String
  versionType       FeatureStatus
  releaseNotes      String?
  changelog         Json?
  deployedAt        DateTime?
  deployedBy        String?
  canRollback       Boolean       @default(true)
  previousVersionId String?
  createdAt         DateTime      @default(now())
  feature           mf_features   @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([featureId, version])
  @@index([featureId])
}

model mf_customer_features {
  id                String               @id @default(uuid())
  customerProfileId String
  featureId         String
  isEnabled         Boolean              @default(true)
  version           String?
  config            Json?
  lastUsedAt        DateTime?
  usageCount        Int                  @default(0)
  enabledAt         DateTime             @default(now())
  disabledAt        DateTime?
  customerProfile   mf_customer_profiles @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  feature           mf_features          @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@unique([customerProfileId, featureId])
  @@index([customerProfileId])
  @@index([featureId])
}

model mf_subscriptions {
  id                 String               @id @default(uuid())
  customerProfileId  String               @unique
  plan               SubscriptionPlan     @default(STARTER)
  billingCycle       BillingCycle         @default(MONTHLY)
  basePrice          Decimal
  perUserPrice       Decimal              @default(0)
  includedUsers      Int                  @default(1)
  maxUsers           Int?
  currentUsers       Int                  @default(1)
  discountPercent    Decimal?             @default(0)
  discountReason     String?
  startDate          DateTime             @default(now())
  currentPeriodStart DateTime             @default(now())
  currentPeriodEnd   DateTime
  nextBillingDate    DateTime
  isOnTrial          Boolean              @default(false)
  trialEndsAt        DateTime?
  isActive           Boolean              @default(true)
  cancelledAt        DateTime?
  cancellationReason String?
  paymentMethod      String?
  lastPaymentAt      DateTime?
  lastPaymentAmount  Decimal?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  invoices           mf_invoices[]
  customerProfile    mf_customer_profiles @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)

  @@index([plan])
  @@index([nextBillingDate])
}

model mf_invoices {
  id                String               @id @default(uuid())
  customerProfileId String
  subscriptionId    String?
  invoiceNumber     String               @unique
  subtotal          Decimal
  discount          Decimal              @default(0)
  tax               Decimal              @default(0)
  total             Decimal
  periodStart       DateTime
  periodEnd         DateTime
  status            String               @default("pending")
  dueDate           DateTime
  paidAt            DateTime?
  paymentMethod     String?
  transactionId     String?
  pdfUrl            String?
  lineItems         Json
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  customerProfile   mf_customer_profiles @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  subscription      mf_subscriptions?    @relation(fields: [subscriptionId], references: [id])

  @@index([customerProfileId])
  @@index([status])
  @@index([dueDate])
}

model mf_bug_reports {
  id                String                @id @default(uuid())
  customerProfileId String?
  title             String
  description       String
  priority          BugPriority           @default(MEDIUM)
  status            BugStatus             @default(OPEN)
  featureKey        String?
  affectedVersion   String?
  browser           String?
  os                String?
  deviceType        String?
  stepsToReproduce  String?
  expectedBehavior  String?
  actualBehavior    String?
  screenshots       String[]              @default([])
  errorLogs         String?
  assignedTo        String?
  resolvedAt        DateTime?
  resolution        String?
  fixedInVersion    String?
  errorStackTrace   String?
  userAgent         String?
  pageUrl           String?
  reportedAt        DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  customerProfile   mf_customer_profiles? @relation(fields: [customerProfileId], references: [id])

  @@index([customerProfileId])
  @@index([priority])
  @@index([status])
  @@index([featureKey])
}

model mf_feature_requests {
  id                   String                @id @default(uuid())
  customerProfileId    String?
  title                String
  description          String
  status               FeatureRequestStatus  @default(SUBMITTED)
  priority             BugPriority           @default(MEDIUM)
  votes                Int                   @default(0)
  votedBy              String[]              @default([])
  targetVersion        String?
  targetFeatureKey     String?
  assignedTo           String?
  estimatedEffort      String?
  implementedAt        DateTime?
  implementedInVersion String?
  rejectionReason      String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  customerProfile      mf_customer_profiles? @relation(fields: [customerProfileId], references: [id])

  @@index([customerProfileId])
  @@index([status])
  @@index([votes])
}

model mf_activity_logs {
  id                String                @id @default(uuid())
  customerProfileId String?
  action            String
  description       String?
  actorType         String
  actorId           String?
  actorEmail        String?
  metadata          Json?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime              @default(now())
  customerProfile   mf_customer_profiles? @relation(fields: [customerProfileId], references: [id])

  @@index([customerProfileId])
  @@index([action])
  @@index([createdAt])
}

model mf_admins {
  id           String    @id @default(uuid())
  firstName    String
  lastName     String
  email        String    @unique
  passwordHash String
  role         InternalRole @default(SOFTWARE_DEVELOPER)
  permissions  Json?
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@index([role])
}

model mf_settings {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
}

model mf_roadmap_items {
  id            String        @id @default(uuid())
  title         String
  description   String?
  featureKey    String?
  status        RoadmapStatus @default(BACKLOG)
  priority      BugPriority   @default(MEDIUM)
  assignedTo    String?
  targetVersion String?
  dueDate       DateTime?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([status])
  @@index([featureKey])
}
